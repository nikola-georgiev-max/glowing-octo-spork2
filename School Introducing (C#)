using System;
using System.Windows.Forms;

namespace SU_PeyoKrYavorov
{
    public class Program
    {
        [STAThread]
        static void Main()
        {
            Application.EnableVisualStyles();
            Application.SetCompatibleTextRenderingDefault(false);

            Form form = new Form();
            form.Text = "СУ \"Пейо Кр. Яворов\"";
            form.Width = 700;
            form.Height = 450;

            Label title = new Label();
            title.Text = "СУ \"Пейо Кр. Яворов\"";
            title.Font = new System.Drawing.Font("Arial", 18, System.Drawing.FontStyle.Bold);
            title.AutoSize = true;
            title.Top = 20;
            title.Left = 20;

            TextBox description = new TextBox();
            description.Multiline = true;
            description.ReadOnly = true;
            description.ScrollBars = ScrollBars.Vertical;
            description.Width = 630;
            description.Height = 280;
            description.Left = 20;
            description.Top = 70;

            description.Text =
@"Средно училище ""Пейо Кр. Яворов"" е образователна институция,
която предоставя качествено обучение и възпитание на своите ученици.

Училището носи името на известния български поет Пейо Крачолов Яворов
и насърчава развитието на знания, умения и творческо мислене.

В него се изучават общообразователни предмети, чужди езици,
информационни технологии, природни и обществени науки.

Учениците участват в различни извънкласни дейности, състезания,
спортни прояви и културни инициативи.

Основната цел на училището е да подготви младите хора за успешно
бъдеще чрез качествено образование, дисциплина и уважение към
общочовешките ценности.";

            form.Controls.Add(title);
            form.Controls.Add(description);

            Application.Run(form);
        }
    }
}
